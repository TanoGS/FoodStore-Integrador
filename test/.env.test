# =============================================================================
# .env.test — Variables de entorno para la SUITE DE TESTS
# =============================================================================
# pytest carga este archivo automáticamente si está configurado en conftest.py.
# Los valores están elegidos para:
#   - NO tocar la base de datos real (usa SQLite en memoria)
#   - Hacer los tests reproducibles y aislados
#   - Permitir que el rate limiter pueda resetearse entre tests
# =============================================================================

# ─── Base de datos ───────────────────────────────────────────────────────────
# Apunta a una BD SQLite en memoria (sobrescribe la lógica de database.py).
# En los tests, el engine se crea con StaticPool para compartir la conexión.
TEST_DATABASE_URL=sqlite:///:memory:

# ─── JWT (autenticación) ─────────────────────────────────────────────────────
# Clave fija para que los tests sean reproducibles.
SECRET_KEY=test-secret-key-fija-para-tests-no-usar-en-produccion-min-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Logging ─────────────────────────────────────────────────────────────────
# WARNING para no contaminar la salida de pytest con logs de la app.
LOG_LEVEL=WARNING

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Los valores de burst deben ser:
#   - Lo suficientemente PEQUEÑOS para que los tests de rate-limit activen 429
#     con sus loops de 80 (default) y 30 (auth) requests.
#   - Lo suficientemente GRANDES para no bloquear los tests funcionales, donde
#     cada test arranca con un bucket lleno (conftest llama reset_all_limiters).
#
# La tasa de refill (per-minute) debe ser LENTA para que el bucket no se
# rellene durante el loop del test (ej: 80 requests a ~5ms c/u = ~400ms;
# con 60/min=1 tok/s solo se recargan 0.4 tokens → el bucket se agota igual).
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_DEFAULT_BURST=20
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AUTH_BURST=8
