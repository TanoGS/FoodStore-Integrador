# ─────────────────────────────────────────────────────────────
# FoodStore Frontend — Variables de entorno (ejemplo)
# ─────────────────────────────────────────────────────────────
# Copiá este archivo a `.env.development` (o `.env.production`)
#   cp .env.example .env.development

# URL base del backend FastAPI.
# - Local:        http://localhost:8000/api/v1
# - ngrok (test): https://xxxx.ngrok-free.app/api/v1
# - Producción:   https://api.tudominio.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Public Key de MercadoPago (solo se usa si en el futuro
# querés usar CardPayment Brick en vez de Checkout PRO)
VITE_MP_PUBLIC_KEY=TEST-abcdef12-3456-7890-abcd-ef1234567890
