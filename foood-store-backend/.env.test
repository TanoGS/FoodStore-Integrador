# =============================================================================
# .env.test — Variables de entorno para la SUITE DE TESTS
# =============================================================================
# pytest carga este archivo automáticamente si está configurado en pytest.ini.
# Los valores están elegidos para:
#   - NO tocar la base de datos real (usa SQLite en memoria o PostgreSQL test)
#   - Hacer los tests reproducibles y aislados
# =============================================================================

# ─── Base de datos ───────────────────────────────────────────────────────────
# Opción A: PostgreSQL (RECOMENDADO — la app usa JSONB y ARRAY que no existen en SQLite)
# Crear una BD: CREATE DATABASE foodstore_test_db;
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodstore_test_db

# Opción B: SQLite en memoria (descomentar si no querés instalar PostgreSQL test)
# ADVERTENCIA: Fallará en tests que usen personalizacion (ARRAY) o JSONB
# TEST_DATABASE_URL=sqlite://

# ─── JWT (autenticación) ─────────────────────────────────────────────────────
SECRET_KEY=test-secret-key-fija-para-tests-no-usar-en-produccion-min-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ─── MercadoPago (mockeado en tests) ────────────────────────────────────────
# No se usa en tests, pero el servicio lo pide
MP_ACCESS_TOKEN=TEST-placeholder
MP_NOTIFICATION_URL=http://localhost:8000/api/v1/pagos/webhook
FRONTEND_URL=http://localhost:5173

# ─── Cloudinary (mockeado en tests) ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=test_cloud
CLOUDINARY_API_KEY=test_key
CLOUDINARY_API_SECRET=test_secret
CLOUDINARY_FOLDER=foodstore_test
CLOUDINARY_MAX_FILE_MB=5
