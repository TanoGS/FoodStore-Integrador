# ─────────────────────────────────────────────────────────────
# FoodStore Backend — Variables de entorno (ejemplo)
# ─────────────────────────────────────────────────────────────
# Copiá este archivo a `.env` y completá los valores reales.
#   cp .env.example .env

# ── App ──
PROJECT_NAME="Food Store API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# ── Base de datos (PostgreSQL) ──
DATABASE_URL=postgresql://foodstore:foodstore@localhost:5432/foodstore_db

# ── Seguridad ──
SECRET_KEY=tu-clave-secreta-cambiar-en-produccion-min-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── MercadoPago (Checkout PRO) ──
# Obtener de: https://www.mercadopago.com.ar/developers/panel/credentials
# Las credenciales TEST- empiezan con "TEST-" (sandbox)
MP_ACCESS_TOKEN=TEST-1234567890123456-XXXXXXXX-XXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MP_PUBLIC_KEY=TEST-abcdef12-3456-7890-abcd-ef1234567890

# URL a la que MP notifica cambios en el pago (IPN).
# ⚠️  Debe ser una URL PÚBLICA accesible desde internet.
# En desarrollo local: usar ngrok (https://xxxx.ngrok.io)
# En producción: tu dominio https://api.tudominio.com
MP_NOTIFICATION_URL=https://tu-subdominio.ngrok-free.app/api/v1/pagos/webhook

# URL del frontend para los back_urls de MP
FRONTEND_URL=http://localhost:5173
